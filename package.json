{
  "name": "@zeing/pino-discord-transport",
  "version": "1.0.4",
  "description": "A transport for Pino that sends logs to a Discord channel via webhook.",
  "keywords": [
    "pino",
    "discord",
    "transport",
    "webhook",
    "logging"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "devDependencies": {
    "@types/bun": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "pino-abstract-transport": "^3.0.0"
  },
  "scripts": {
    "build": "bun run build.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "publish": "bun run build && bun publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeing/pino-discord-transport.git"
  },
  "author": "zeing",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zeing/pino-discord-transport/issues"
  },
  "homepage": "https://github.com/zeing/pino-discord-transport#readme"
}
